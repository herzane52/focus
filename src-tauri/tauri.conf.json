{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focus",
  "version": "1.3.1",
  "identifier": "tr.herzane.focus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "",
    "frontendDist": "../build/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Focus | Profesyonel Takip",
        "width": 1600,
        "height": 900,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://localhost:* http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage"
    ],
    "publisher": "Herzane",
    "category": "Productivity",
    "shortDescription": "Profesyonel Takip ve Odaklanma Uygulaması",
    "longDescription": "Focus, ders çalışma akışınızı yönetmenize ve verimliliğinizi artırmanıza yardımcı olan gelişmiş bir takip uygulamasıdır.",
    "linux": {
      "deb": {
        "depends": [
          "libgtk-3-0",
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "librsvg2-common"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}